  output_dir: /mnt/output/qwen3-14B-tom-sft-stage9
track_with: stdout
tracker_kwargs: {}
num_gpus_per_node: 8
save_steps: 50
logging_steps: 5
eval_steps: 200
resume_from_checkpoint: false
sequence_length: 1536
pretrain: Qwen/Qwen3-14B
system_key: system
prompt_key: prompt
response_key: response
validation:
  data_args:
    file_name: /mnt/data/tom_train_sft_val.jsonl
    template: qwen3
sft_train:
  model_args:
    dtype: bf16
  training_args:
    num_train_epochs: 3
    per_device_train_batch_size: 1
