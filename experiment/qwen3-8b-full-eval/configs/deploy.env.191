# Qwen3-8B full-eval deployment env (server 172.16.120.191)
# Used by experiment/qwen3-8b-full-eval/scripts/* — NOT a substitute for the
# top-level configs/deploy.env which targets 181.

TRAIN_HOST=h800@172.16.120.191
TRAIN_SSH_KEY=~/.ssh/id_ed25519

# Where the experiment lives on the remote (sync target)
REMOTE_BASE=/home/h800/grj-projects/qwen3-tom
REMOTE_EXP_DIR=${REMOTE_BASE}/experiment/qwen3-8b-full-eval

# Model paths on 191
BASE_MODEL_PATH=/model/Qwen3-8B
V10_MODEL_PATH=/home/h800/xujiayuan/models/qwen3-8B-tombench-rlvr-stage15-1x8-hf-ckpt150

# Eval data on 191
EVAL_TOMBENCH=/home/h800/grj-projects/qwen3-tom/data/tom/tombench_eval.jsonl
EVAL_HITOM=/home/h800/grj-projects/qwen3-tom/data/eval/hitom_eval.jsonl

# vLLM image (already pulled on 191)
VLLM_IMAGE=vllm/vllm-openai:v0.11.0

# Per-instance vLLM params
MAX_MODEL_LEN=8192
GPU_UTIL=0.85

# Port assignment (TP=1, single GPU per instance)
# 8001-8004 → 8B base on GPU 0..3
# 8005-8008 → 8B v1.0 on GPU 4..7
BASE_PORTS="8001 8002 8003 8004"
V10_PORTS="8005 8006 8007 8008"

# Model names served (must match what vLLM exposes; client uses these as the OpenAI `model` param)
BASE_MODEL_NAME=qwen3-8b-base
V10_MODEL_NAME=qwen3-8b-v10

# DashScope (Alibaba ModelScope) — third eval target: qwen3-8b API
# Key/base_url come from ~/.zshrc:
#   DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   DASHSCOPE_API_KEY=sk-...
# We pin enable_thinking via chat_template_kwargs per protocol (see parallel_eval.py).
DASHSCOPE_MODEL_NAME=qwen3-8b
DASHSCOPE_MODEL_ID=qwen3-8b-api
