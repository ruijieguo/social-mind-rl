# Qwen3-14B full-eval deployment env (server 172.16.120.181 / h800-3).
# Used by experiment/qwen3-14b-full-eval/scripts/*.
#
# This host runs another job on GPUs 0-3, so this eval is confined to GPUs 4-7
# (see docker/docker-compose.yml device_ids). 4 × TP=1 vLLM instances, one model
# at a time (base → v3.5 → v3.1), all 4 benchmarks per model, then swap.

TRAIN_HOST=h800@172.16.120.181
TRAIN_SSH_KEY=~/.ssh/id_ed25519

# Repo + experiment location on the remote
REMOTE_BASE=/data_nvme/grj-projects/qwen3-tom
REMOTE_EXP_DIR=${REMOTE_BASE}/experiment/qwen3-14b-full-eval

# Host dir mounted read-only into every serve container (covers all 3 models +
# the downloaded base). Mounted at the SAME absolute path inside the container,
# so MODEL_PATH below is valid both on host and in container.
MODEL_HOST_DIR=/data_nvme/grj-projects

# --- The 3 models under eval -------------------------------------------------
# base = original Qwen/Qwen3-14B (downloaded from ModelScope to this path)
BASE_MODEL_PATH=/data_nvme/grj-projects/models/Qwen3-14B
BASE_MODEL_NAME=qwen3-14b-base
BASE_MODEL_ID=base

# v3.5 = Stage 19 ckpt-120
V35_MODEL_PATH=/data_nvme/grj-projects/tom-output/qwen3-14B-tombench-rlvr-stage19-1x8-hf-ckpt120
V35_MODEL_NAME=qwen3-14b-v35
V35_MODEL_ID=v35

# v3.1 = Stage 14b ckpt-199
V31_MODEL_PATH=/data_nvme/grj-projects/tom-output/qwen3-14B-tombench-rlvr-stage14b-1x8-hf-ckpt199
V31_MODEL_NAME=qwen3-14b-v31
V31_MODEL_ID=v31

# --- Eval data (synced from DEV into the host repo) ---------------------------
EVAL_TOMBENCH=/data_nvme/grj-projects/qwen3-tom/data/tom/tombench_eval.jsonl
EVAL_HITOM=/data_nvme/grj-projects/qwen3-tom/data/eval/hitom_eval.jsonl
EVAL_SOCIALIQA=/data_nvme/grj-projects/qwen3-tom/data/eval/socialiqa_eval.jsonl
EVAL_EMOBENCH=/data_nvme/grj-projects/qwen3-tom/data/eval/emobench_eval.jsonl

# --- vLLM serve params -------------------------------------------------------
# 8 GPUs (0-7) freed up → 8 endpoints, ~2× throughput vs the original 4-GPU run.
SERVE_PORT_BASE=8001
PORTS="8001 8002 8003 8004 8005 8006 8007 8008"
MAX_MODEL_LEN=16384
GPU_UTIL=0.85

# Eval client concurrency (8 endpoints share this; total in-flight = 8 × per-ep)
CONCURRENCY=128
