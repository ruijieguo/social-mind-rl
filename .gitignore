# macOS
.DS_Store

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/
.venv/
venv/

# Runtime products (will be regenerated)
/data/
output/
# But DO track training data so it's reproducible across machines.
# raw/ contains the per-source jsonls (ToMBench ingest, exploretom,
# simpletom, synth*); the merged tom_train*.jsonl + dedup_report +
# eval files are the canonical training/eval artifacts.
!/data/tom/
!/data/tom/raw/
!/data/tom/raw/*.jsonl
!/data/tom/*.jsonl
!/data/tom/*.json
# Eval files have known sizes (~2-3 MB), train data ~100 MB total,
# all small enough for git (no need for git-lfs).

# Local deployment env
configs/deploy.env

# Editor / IDE
.idea/
.vscode/
*.swp

# Framework submodules (managed separately)
# Ignore everything in framework/ROLL by default, with specific exceptions
# for our custom additions (worker + test). We descend into the tree using
# directory exceptions, then re-ignore "everything else" at each level.
framework/ROLL/*
!framework/ROLL/roll/
framework/ROLL/roll/*
!framework/ROLL/roll/pipeline/
framework/ROLL/roll/pipeline/*
!framework/ROLL/roll/pipeline/rlvr/
framework/ROLL/roll/pipeline/rlvr/*
!framework/ROLL/roll/pipeline/rlvr/rewards/
framework/ROLL/roll/pipeline/rlvr/rewards/*
!framework/ROLL/roll/pipeline/rlvr/rewards/tom_mcq_reward_worker.py
!framework/ROLL/tests/
framework/ROLL/tests/*
!framework/ROLL/tests/test_tom_mcq_reward.py

# Eval cache
output/eval_cache/

# TensorBoard
output/tensorboard/

# Checkpoints (synced from TRAIN)
output/checkpoints/

# API usage logs
output/api_usage.jsonl

# manifests (regenerated)
output/manifests/

# Local docker volumes
docker_volumes/
.claude/
framework/ExploreToM

# Git worktrees (isolated experiment workspaces)
.worktrees/

# 27B experiment training data (large; lives on TRAIN, not in repo).
# Code (configs/, scripts/, docs/, README) IS tracked.
experiment/qwen3.6-27b/data/*.jsonl

# API keys / secrets
.env
*.env
